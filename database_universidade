-- Exemplo 4 criação da tabela Matrícula
CREATE TABLE IF NOT EXISTS matricula(
  matricula INT,
  codcurso INT,
  dtmatricula DATE,
  PRIMARY key (matricula, codcurso),
  foreign key(matricula) references aluno(matricula),
  foreign key(codcurso) REFERENCES curso(codcurso)
  );
